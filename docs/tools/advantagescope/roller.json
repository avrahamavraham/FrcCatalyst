{
  "$schema": "../catalyst-tab-bundle.schema.json",
  "catalystVersion": "0.8.0",
  "mechanism": "RollerMechanism",
  "description": "Roller / intake duty-cycle and stall-detection dashboard.",
  "placeholders": {
    "MECH": "Replace with the RollerMechanism name (e.g. Intake, Indexer, Feeder)."
  },
  "tabs": [
    {
      "title": "{MECH} — Drive",
      "type": "LineGraph",
      "axes": {
        "left": {
          "unit": "dutyCycle",
          "fields": [
            { "key": "/Catalyst/{MECH}/Speed", "color": "#e94560" }
          ]
        },
        "right": {
          "unit": "amps",
          "fields": [
            { "key": "/Catalyst/{MECH}/CurrentAmps", "color": "#f59e0b" }
          ]
        }
      }
    },
    {
      "title": "{MECH} — Game piece",
      "type": "LineGraph",
      "axes": {
        "left": {
          "unit": "boolean",
          "fields": [
            { "key": "/Catalyst/{MECH}/HasPiece", "color": "#4ade80" }
          ]
        },
        "right": {
          "unit": "rotations",
          "fields": [
            { "key": "/Catalyst/{MECH}/MotorRotations", "color": "#60a5fa" }
          ]
        }
      }
    }
  ]
}
